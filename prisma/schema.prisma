datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Questions {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  content   String?
  published Boolean   @default(false)
  author    User?     @relation(fields: [authorId], references: [id])
  authorId  String    @db.ObjectId
  postId    String    @unique
  answers   Answers[]
}

model Answers {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  content   String?
  published Boolean    @default(false)
  author    User?      @relation(fields: [authorId], references: [id])
  authorId  String     @db.ObjectId
  post      Questions? @relation(fields: [postId], references: [postId])
  postId    String
}

model Reviews {
  id           String  @id @default(auto()) @map("_id") @db.ObjectId
  title        String
  review       String
  totalAmounts Float
  rate         Float
  photo        String?
  hospitalId   String
  categories   Json?
  createdAt    String
  user         User?   @relation(fields: [userId], references: [id])
  userId       String  @db.ObjectId
}

model User {
  id        String      @id @default(auto()) @map("_id") @db.ObjectId
  email     String      @unique
  name      String
  image     String
  password  String
  Questions Questions[]
  Answers   Answers[]
  Reviews   Reviews[]
}
